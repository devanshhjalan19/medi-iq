# LLM_PROVIDER: gemini | openai | anthropic | openrouter
LLM_PROVIDER=gemini
LLM_API_KEY=paste_key_here

# EMBEDDING_API_KEY only needed if provider is anthropic/openrouter
# (they have no embeddings). Use an OpenAI key there.
EMBEDDING_API_KEY=

# Optional model overrides (blank -> provider defaults)
LLM_MODEL=gemini/gemini-3.1-flash-lite
EMBEDDING_MODEL=gemini/gemini-embedding-001
